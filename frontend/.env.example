# Public API base URL for the frontend.
# Example:
# NEXT_PUBLIC_API_URL=https://s2a-backend.onrender.com/api
NEXT_PUBLIC_API_URL=http://localhost:8000/api

# Backend URL (server-side only, used by Next.js rewrites and NextAuth.js).
# In production (e.g. Vercel), set this to the Render backend URL.
# Example:
# BACKEND_URL=https://s2a-backend.onrender.com
BACKEND_URL=http://localhost:8000

# NextAuth.js / Auth.js 設定
# シークレットキー（本番環境では必ずランダムな値を設定すること）
# 生成例: openssl rand -base64 32
# ※ next-auth v5 (Auth.js) では AUTH_SECRET を使用（NEXTAUTH_SECRET は v4 の名前）
AUTH_SECRET=your-secret-key-here
NEXTAUTH_URL=http://localhost:3000

# Google OAuth 認証情報
# Google Cloud Console で OAuth 2.0 クライアント ID を作成してください:
# https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# Switch 連携 API キー（バックエンドの BACKEND_API_KEY と同じ値を設定）
# 生成例: openssl rand -hex 32
NEXT_PUBLIC_BACKEND_API_KEY=

# Google OAuth 許可メールアドレス（カンマ区切り）
# バックエンドDBに未登録のユーザーでも、ここに記載されていればログインを許可する
# 例: ALLOWED_EMAILS=parent@example.com,admin@example.com
ALLOWED_EMAILS=
